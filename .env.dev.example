COMPOSE_PROJECT_NAME=bonga_dev
POSTGRES_DB=your_dev_db
POSTGRES_USER=your_dev_user
POSTGRES_PASSWORD=change_me_dev_password
POSTGRES_PORT=55432

# ============================================================================
# Cloud Storage Configuration (Optional)
# ============================================================================
# Uncomment and configure the storage backend you want to use:
# STORAGE_TYPE: s3, azure, or gcs

# AWS S3
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=your-ecommerce-data-bucket
# S3_PREFIX=data/ecommerce

# Azure Blob Storage
# STORAGE_TYPE=azure
# AZURE_STORAGE_ACCOUNT=yourstorageaccount
# AZURE_STORAGE_KEY=your_storage_account_key
# AZURE_CONTAINER=private-data

# Google Cloud Storage (GCS)
# STORAGE_TYPE=gcs
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_BUCKET=your-ecommerce-data-bucket

# Data Directory
# DATA_DIR=./data/private
